{
  "manifest_version": 3,
  "name": "ClearFeed",
  "version": "2.5",
  "description": "Clean your feed and focus on what matters. Mute topics you'd rather not see — politics, gossip, spoilers or any keywords.",
  "author": "Martin Svoboda",
  "homepage_url": "https://github.com/Martin8O/ClearFeed",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-blocking": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Turn ClearFeed filtering on or off"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
